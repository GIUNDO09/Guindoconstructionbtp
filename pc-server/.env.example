# Copier ce fichier en ".env" et remplir les valeurs

# URL et clé publishable de ton projet Supabase (pour vérifier les tokens)
SUPABASE_URL=https://aqbtphtqurkunfawnvvg.supabase.co
SUPABASE_KEY=sb_publishable_mBWoSWwDqj_lfP6yNAk6VQ_M6ZYGeVI

# CLÉ SECRÈTE (service_role) — utilisée UNIQUEMENT par le Manager pour
# publier l'URL du tunnel dans Supabase automatiquement.
# À récupérer sur : https://supabase.com/dashboard/project/aqbtphtqurkunfawnvvg/settings/api
# section "Project API keys" → "service_role" (secret). NE JAMAIS EXPOSER côté client.
SUPABASE_SERVICE_ROLE_KEY=

# Port local sur lequel le serveur écoute (par défaut 3000)
PORT=3000

# Dossier où stocker les fichiers sur le disque (sera créé s'il n'existe pas)
FILES_DIR=C:\\gcbtp-files

# Origine autorisée (le site Vercel qui accède à ce serveur)
CORS_ORIGIN=https://www.guindoconstruction.xyz

# Taille max d'un fichier uploadé (en Mo)
MAX_FILE_MB=100
